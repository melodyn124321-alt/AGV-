<?xml version="1.0" encoding="UTF-8" ?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>UdpTransport</transport_id>
            <type>UDPv4</type>
            <sendBufferSize>104857600</sendBufferSize>
            <receiveBufferSize>104857600</receiveBufferSize>
            <non_blocking_send>false</non_blocking_send>
            <maxMessageSize>65500</maxMessageSize>
            <maxInitialPeersRange>100</maxInitialPeersRange>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="default_profile" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>UdpTransport</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>

            <times>
                <heartbeatPeriod>
                    <sec>0</sec>
                    <nanosec>100000000</nanosec>
                </heartbeatPeriod>
                <heartbeatResponseDelay>
                    <sec>0</sec>
                    <nanosec>50000000</nanosec>
                </heartbeatResponseDelay>
                <initialHeartbeatDelay>
                    <sec>0</sec>
                    <nanosec>50000000</nanosec>
                </initialHeartbeatDelay>
                <nackResponseDelay>
                    <sec>0</sec>
                    <nanosec>50000000</nanosec>
                </nackResponseDelay>
                <nackSupressionDuration>
                    <sec>0</sec>
                    <nanosec>100000000</nanosec>
                </nackSupressionDuration>
            </times>

            <builtin>
                <initialPeersList>
                    <locator>
                        <udpv4>
                            <address>10.200.24.83</address>
                            <port>7400</port>
                        </udpv4>
                    </locator>
                </initialPeersList>
                <metatrafficUnicastLocatorList>
                    <locator>
                        <udpv4>
                            <address>0.0.0.0</address>
                            <port>7400</port>
                        </udpv4>
                    </locator>
                </metatrafficUnicastLocatorList>
                <discovery_config>
                    <discoveryProtocol>SIMPLE</discoveryProtocol>
                    <ignoreParticipantFlags>NO_FILTER</ignoreParticipantFlags>
                    <leaseDuration>
                        <sec>10</sec>
                        <nanosec>0</nanosec>
                    </leaseDuration>
                    <leaseAnnouncement>
                        <sec>3</sec>
                        <nanosec>0</nanosec>
                    </leaseAnnouncement>
                    <initialAnnouncements>
                        <count>10</count>
                        <period>
                            <sec>0</sec>
                            <nanosec>100000000</nanosec>
                        </period>
                    </initialAnnouncements>
                </discovery_config>
            </builtin>

            <port>
                <offset>0</offset>
                <domainIDGain>250</domainIDGain>
                <participantIDGain>2</participantIDGain>
            </port>

            <defaultUnicastLocatorList>
                <locator>
                    <udpv4>
                        <address>0.0.0.0</address>
                    </udpv4>
                </locator>
            </defaultUnicastLocatorList>
        </rtps>
    </participant>
</profiles>
